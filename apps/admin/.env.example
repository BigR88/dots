# Admin-Login (PFLICHT): gemeinsames Passwort für das Admin-Gate.
# Ohne diesen Wert ist das gesamte Admin gesperrt (HTTP 503) — sicherer Default,
# weil alle Aktionen über den Service-Role-Key laufen. Langes Passwort wählen.
ADMIN_PASSWORD=ein-langes-admin-passwort
# Optional: eigener Schlüssel zum Signieren des Session-Cookies. Default ist das
# Passwort selbst (ein Passwortwechsel meldet dann alle Sessions ab).
# ADMIN_SESSION_SECRET=langer-zufalls-string

# Supabase-Verbindung für das Admin (nur serverseitig genutzt).
# Kopie als `.env.local` anlegen. Der Service-Role-Key ist GEHEIM:
# niemals committen, niemals in Client-Code importieren.
SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# KI-Import-Agent: Anthropic-API-Key für die Event-Extraktion (GEHEIM, serverseitig).
# Key unter https://console.anthropic.com → API Keys erstellen.
ANTHROPIC_API_KEY=sk-ant-...
# Optionale Modell-Overrides (Defaults: Sonnet 4.6 für Text, Opus 4.8 für Bilder):
# DOTS_IMPORT_TEXT_MODEL=claude-sonnet-4-6
# DOTS_IMPORT_VISION_MODEL=claude-opus-4-8

# Cron: Shared Secret für POST/GET /api/cron/scan (scannt fällige Quellen).
# Ohne diesen Wert ist der Cron-Endpunkt deaktiviert (503).
# CRON_SECRET=langer-zufalls-string
